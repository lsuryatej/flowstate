{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flowstate",
  "version": "0.1.0",
  "identifier": "com.suryatejlalam.flowstate",
  "build": {
    "beforeDevCommand": "bun run build:sidecar && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build:sidecar && bun run build && node scripts/build-sidecar-binary.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "flowstate",
        "width": 800,
        "height": 600
      },
      {
        "label": "capture",
        "url": "capture.html",
        "title": "capture",
        "width": 560,
        "height": 96,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/flowstate-sidecar", "binaries/claude"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
